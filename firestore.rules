rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // users collection: only the authenticated owner may read or write their document
    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      function serverManagedFieldsUnchanged() {
        let managed = ["fcmTokens", "pushEnabled"];
        return !request.resource.data.keys().hasAny(managed) ||
          (
            resource != null &&
            request.resource.data.fcmTokens == resource.data.fcmTokens &&
            request.resource.data.pushEnabled == resource.data.pushEnabled
          );
      }

      // Allow reads for leaderboard visibility; restrict writes to owner
      allow read: if true;
      allow create, update: if isOwner() && serverManagedFieldsUnchanged();
      allow delete: if isOwner();
    }

    // messages collection: authenticated users can create messages; everyone can read
    match /messages/{messageId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll(["text", "timestamp"]) &&
        request.resource.data.text is string &&
        request.resource.data.text.size() <= 2000;
      // allow updates and deletes only for message owner
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // default: deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
